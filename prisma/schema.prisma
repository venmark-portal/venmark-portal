generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Brugere ─────────────────────────────────────────────────────────────────

model Customer {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String
  bcCustomerNumber  String   @unique
  bcPriceGroup      String?
  bcStandardSalesCode String?  // Standard Sales Code i BC — bruges til favoritliste
  phone            String?
  address          String?
  city             String?
  zipCode          String?
  isActive         Boolean  @default(true)
  bcBlocked        Boolean  @default(false)  // Spærret i BC — blokerer login uanset isActive
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  favorites      Favorite[]
  blocked        BlockedItem[]
  orders         Order[]
  standingOrders StandingOrder[]
  tickets        Ticket[]
  deliveryProfile DeliveryProfile?
  specialVareReservations SpecialVareReservation[]
  pushSubscriptions   PushSubscription[]
  messages            Message[]
  deliveryCode        String?  // leveringskode — bruges til gruppevis push-notifikationer
  requirePoNumber     Boolean  @default(false)
  bcDebitorBookingGroup String? // e.g. "Salling", "COOP" — triggers mandatory PO
  contacts            ContactUser[]
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

// ─── Favoritvarer og skjulte varer ───────────────────────────────────────────

model Favorite {
  id           String   @id @default(cuid())
  customer     Customer @relation(fields: [customerId], references: [id])
  customerId   String
  bcItemNumber String
  itemName     String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  @@unique([customerId, bcItemNumber])
}

model BlockedItem {
  id           String   @id @default(cuid())
  customer     Customer @relation(fields: [customerId], references: [id])
  customerId   String
  bcItemNumber String
  createdAt    DateTime @default(now())

  @@unique([customerId, bcItemNumber])
}

// ─── Dagens anbefalinger (styres af admin) ────────────────────────────────────

model DailyPromotion {
  id           String   @id @default(cuid())
  bcItemNumber String
  itemName     String
  date         DateTime
  priority     Int      @default(0)
  note         String?
  createdAt    DateTime @default(now())

  @@unique([bcItemNumber, date])
}

// ─── Faste ordrer (ugentlige skabeloner) ─────────────────────────────────────

model StandingOrder {
  id         String    @id @default(cuid())
  customer   Customer  @relation(fields: [customerId], references: [id])
  customerId String
  weekday    Int       // 1=Man 2=Tir 3=Ons 4=Tor 5=Fre
  name       String?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  lines StandingOrderLine[]
}

model StandingOrderLine {
  id              String        @id @default(cuid())
  standingOrder   StandingOrder @relation(fields: [standingOrderId], references: [id], onDelete: Cascade)
  standingOrderId String
  bcItemNumber    String
  itemName        String
  quantity        Float
  uom             String        @default("STK")
  sortOrder       Int           @default(0)

  @@unique([standingOrderId, bcItemNumber])
}

// ─── Reklamationer og support-tickets ────────────────────────────────────────

model Ticket {
  id         String          @id @default(cuid())
  customer   Customer        @relation(fields: [customerId], references: [id])
  customerId String
  type       String          @default("COMPLAINT")  // COMPLAINT | SMS_ORDER | MAIL_ORDER
  subject    String
  body       String
  status     String          @default("OPEN")        // OPEN | IN_PROGRESS | CLOSED
  orderRef   String?
  images     TicketImage[]
  messages   TicketMessage[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model TicketImage {
  id        String   @id @default(cuid())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  String
  data      String
  mimeType  String
  fileName  String
  createdAt DateTime @default(now())
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId   String
  sender     String
  senderName String?
  body       String
  readByCustomer      Boolean  @default(true)   // false = unread for customer (staff reply)
  createdAt  DateTime @default(now())
}

// ─── Leveringsprofil ─────────────────────────────────────────────────────────

model DeliveryProfile {
  id                  String          @id @default(cuid())
  customer            Customer        @relation(fields: [customerId], references: [id])
  customerId          String          @unique
  doorCode            String?         // Dørkodenummer
  keyboxCode          String?         // Nøglebokskode
  alarmCode           String?         // Alarmkode
  deliveryDescription String?         // Beskrivelse af leveringssted (fri tekst)
  driverMessage       String?         // Fast tilbagevendende besked til chauffør
  photos              DeliveryPhoto[]
  updatedAt           DateTime        @updatedAt
}

model DeliveryPhoto {
  id        String          @id @default(cuid())
  profile   DeliveryProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String
  data      String          // base64
  mimeType  String
  fileName  String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
}

// ─── Kontakt-brugere (ansatte der kan bestille for kunden) ───────────────────

model ContactUser {
  id           String   @id @default(cuid())
  customer     Customer @relation(fields: [customerId], references: [id])
  customerId   String
  email        String   @unique
  passwordHash String
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Venmark anbefalede varer ("sælg for helvede") ───────────────────────────

model VenmarkRecommended {
  id           String   @id @default(cuid())
  bcItemNumber String   @unique
  itemName     String
  note         String?  // Salgstip / kommentar
  priority     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Portal-udseende (admin-styret) ──────────────────────────────────────────

model PortalSettings {
  id                  String   @id @default("default")
  bgColor             String   @default("#eff6ff")
  bannerEnabled       Boolean  @default(false)
  bannerText          String?
  bannerBgColor       String   @default("#1e40af")
  bannerTextColor     String   @default("#ffffff")
  kvalitetschefEmail  String?  // Modtager eskaleringsmail ved manglende leverandørerklæring
  updatedAt           DateTime @updatedAt
}

// ─── Ordrer ───────────────────────────────────────────────────────────────────

model Order {
  id            String    @id @default(cuid())
  customer      Customer  @relation(fields: [customerId], references: [id])
  customerId    String
  bcOrderNumber String?
  bcOrderId     String?   // BC ordre GUID (kræves til at tilføje linjer via API)
  type          String    @default("ONEOFF")     // ONEOFF | STANDING
  status        String    @default("DRAFT")      // DRAFT | SUBMITTED | APPROVED | SENT_TO_BC | CONFIRMED | REJECTED
  deliveryDate  DateTime
  deadline      DateTime
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  submittedAt   DateTime?
  approvedAt    DateTime?
  approvedBy    String?
  driverNote          String?   // Ekstra besked pr. levering — bekræftes af chauffør
  driverConfirmed     Boolean   @default(false)
  driverConfirmedAt   DateTime?
  poNumber            String?
  orderedByName       String?  // navn på person der bestilte (evt. kontakt-bruger)
  orderedByEmail      String?

  lines OrderLine[]
}

model OrderLine {
  id           String @id @default(cuid())
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  bcItemNumber String
  itemName     String
  quantity     Float
  uom          String @default("STK")
  unitPrice    Float  @default(0)
  status       String @default("PENDING") // PENDING | APPROVED | REJECTED
}

// ─── Levering & Logistik ──────────────────────────────────────────────────────

model DriverUser {
  id                   String      @id @default(cuid())
  name                 String
  phone                String?
  email                String?
  pinHash              String
  isDefault            Boolean     @default(false)
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  bcDriverCode         String?     @unique
  defaultVehicleLabel  String      @default("Bil 1")
  bcShipmentMethodCode String?
  vehicles             RouteVehicle[] @relation("VehicleDriver")
  stops                RouteStop[]
}

model DeliveryCode {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  description String?
  createdAt   DateTime          @default(now())
  contacts    DeliveryContact[]
  stops       RouteStop[]
}

model DeliveryContact {
  id             String       @id @default(cuid())
  deliveryCode   DeliveryCode @relation(fields: [deliveryCodeId], references: [id], onDelete: Cascade)
  deliveryCodeId String
  name           String
  email          String?
  phone          String?
  role           String       @default("transporter") // "transporter" | "internal"
}

model DeliveryRoute {
  id          String         @id @default(cuid())
  bookingDate DateTime
  status      String         @default("DRAFT") // DRAFT | ACTIVE | COMPLETED
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  vehicles    RouteVehicle[]
}

model RouteVehicle {
  id           String        @id @default(cuid())
  route        DeliveryRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  routeId      String
  vehicleLabel String        @default("Bil 1")
  driver       DriverUser?   @relation("VehicleDriver", fields: [driverId], references: [id])
  driverId     String?
  sortOrder    Int           @default(0)
  stops        RouteStop[]
}

model RouteStop {
  id                   String        @id @default(cuid())
  vehicle              RouteVehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId            String
  driver               DriverUser?   @relation(fields: [driverId], references: [id])
  driverId             String?
  sortOrder            Int
  deliveryCode         DeliveryCode? @relation(fields: [deliveryCodeId], references: [id])
  deliveryCodeId       String?
  deliveryCodeOverride String?

  // BC referencer
  bcSalesOrderNo    String?
  bcSalesOrderId    String?
  bcPurchaseOrderNo String?
  bcPurchaseOrderId String?

  // Ekstra opgave (ikke BC-ordre)
  isExtraTask    Boolean @default(false)
  extraTaskTitle String?
  extraTaskNote  String?

  // Cachet kundeinformation (til offline-brug)
  customerName    String?
  customerAddress String?
  customerPhone   String?
  totalWeightKg   Float?

  // Status
  status      String    @default("PENDING") // PENDING | DELIVERED | FAILED | SKIPPED
  deliveredAt DateTime?
  failureNote String?
  packedStatus String?  // læst fra BC: READY | PARTIAL | PENDING

  kobSalesOrderNo String?
  createdAt       DateTime    @default(now())
  photos          RouteStopPhoto[]
}

model RouteStopPhoto {
  id        String    @id @default(cuid())
  stop      RouteStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  stopId    String
  filename  String
  takenAt   DateTime  @default(now())
  expiresAt DateTime
  lat       Float?
  lng       Float?
}

model CustomerRouteProfile {
  customerNo     String   @id
  routeOrder     Int      @default(5000)
  defaultVehicle Int      @default(0)
  updatedAt      DateTime @updatedAt
}

model PodRecipient {
  id           String  @id @default(cuid())
  bcCustomerNo String
  name         String?
  email        String?
  phone        String?
  sendEmail    Boolean @default(false)
  sendSms      Boolean @default(false)
  sortOrder    Int     @default(0)
}

// ─── Specialvarer (Netvarer) ──────────────────────────────────────────────────
// Oprettes automatisk fra BC når en Netvare-kasse registreres.
// Vises øverst på bestillingssiden og udløber automatisk kl. 23:59 samme dag.

model SpecialVare {
  id           String   @id @default(cuid())
  bcItemNumber String
  itemName     String
  boxEntryNo   Int?     // BC Portal Production Box Entry No. → kobler til foto
  availableKg  Float
  reservedKg   Float    @default(0)
  pricePerKg   Float?   // valgfri — vises på portalen
  note         String?
  expiresAt    DateTime // automatisk sat til i dag kl. 23:59
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  reservations SpecialVareReservation[]

  @@index([isActive, expiresAt])
}

model SpecialVareReservation {
  id            String      @id @default(cuid())
  specialVare   SpecialVare @relation(fields: [specialVareId], references: [id], onDelete: Cascade)
  specialVareId String
  customer      Customer    @relation(fields: [customerId], references: [id])
  customerId    String
  kg            Float
  status        String      @default("PENDING") // PENDING | CONFIRMED | CANCELLED
  orderId       String?     // sættes når overført til ordre
  createdAt     DateTime    @default(now())

  @@index([customerId, status])
  @@index([specialVareId])
}

// ─── Kassefoto-system ─────────────────────────────────────────────────────────
// Fotos tages automatisk ved label-print via foto-station i browser.
// Kobles til salgsordre/kunde når kassen scannes.
// Slettes automatisk efter 7 dage via cleanup-job.

model BoxPhoto {
  id             String   @id @default(cuid())
  bcBoxEntryNo   Int      // Portal Production Box Entry No. i BC
  filePath       String   // relativ sti: uploads/boxfotos/YYYY-MM/id.jpg
  takenAt        DateTime @default(now())
  expiresAt      DateTime // takenAt + 7 dage
  bcSalesOrderNo String?  // sættes når kassen scannes til salgsordre
  bcCustomerNo   String?  // sættes når kassen scannes til salgsordre
  boxWeight      Float?   // kopi af Box.Weight fra BC (til hurtig visning)
  itemNo         String?  // kopi af Box.ItemNo

  @@index([bcBoxEntryNo])
  @@index([bcSalesOrderNo])
  @@index([bcCustomerNo])
  @@index([expiresAt])
}

// PendingCapture: BC opretter en post når label printes.
// Foto-stationen poller og fanger billedet, markerer captured = true.
model PendingCapture {
  id           String   @id @default(cuid())
  bcBoxEntryNo Int
  stationId    String   @default("default") // til flere pakstationer
  requestedAt  DateTime @default(now())
  captured     Boolean  @default(false)

  @@index([stationId, captured])
}

// BoxPallet: gruppe af kasser/subtotaler der udgør en palle.
// Oprettes når palle-label printes eller palle scannes færdig.
model BoxPallet {
  id             String   @id @default(cuid())
  palletRef      String   @unique // barcode-reference (f.eks. PAL-{id})
  bcSalesOrderNo String?
  bcCustomerNo   String?
  createdAt      DateTime @default(now())
  boxEntries     String   @default("[]") // JSON-array af bcBoxEntryNo
}

// ─── Beskeder (admin ↔ kunde) ─────────────────────────────────────────────────

model Message {
  id             String   @id @default(cuid())
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId     String
  sender         String   // 'admin' | 'customer'
  senderName     String?
  body           String
  readByAdmin    Boolean  @default(false)
  readByCustomer Boolean  @default(false)
  createdAt      DateTime @default(now())
  expiresAt      DateTime // createdAt + 30 dage

  @@index([customerId, createdAt])
  @@index([expiresAt])
}

// ─── Push-notifikationsabonnementer ──────────────────────────────────────────

model PushSubscription {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  @@index([customerId])
}

// ─── Password reset tokens ────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Leverandørerklæringer ────────────────────────────────────────────────────

model SupplierDeclaration {
  id              String    @id @default(cuid())
  bcVendorNo      String    // BC leverandørnummer
  token           String    @unique @default(cuid()) // URL-token til leverandørens adgang
  lang            String    @default("da") // da/sv/en/de/fr/nl/it/es

  // Stamdata
  companyName     String?
  vatNo           String?
  address         String?
  country         String?
  phone           String?
  email           String?
  contactPerson   String?
  qualityManager  String?
  emergencyPhone  String?

  // Certificeringer
  hasThirdPartyCert     Boolean?
  certTypes             String?  // JSON-array: ["ISO22000","FSSC","BRC","IFS","MSC","ASC",...]
  certNumber            String?
  certExpiry            DateTime?
  hasMsc                Boolean?
  mscCertNumber         String?
  mscExpiry             DateTime?

  // HACCP (JSON: { key: "ja"|"nej"|"n/a", comment?: string })
  haccpAnswers          String?

  // Egenkontrol (JSON: { key: "ja"|"nej"|"n/a", comment?: string })
  selfControlAnswers    String?

  // Digital godkendelse
  signerName            String?
  signerTitle           String?
  signerEmail           String?
  confirmedAt           DateTime?
  ipAddress             String?

  // Status + datoer
  status          String    @default("PENDING") // PENDING | SUBMITTED | APPROVED | EXPIRED
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedBy      String?   // admin email
  nextRenewalDate DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  documents       SupplierDocument[]
  reminders       SupplierReminderLog[]

  @@index([bcVendorNo])
  @@index([status])
  @@index([nextRenewalDate])
  @@index([token])
}

model SupplierDocument {
  id            String              @id @default(cuid())
  declaration   SupplierDeclaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  declarationId String
  docType       String  // CERT_BRC | CERT_IFS | CERT_MSC | CERT_OTHER | HACCP | AUDIT | WATER | PEST | RECALL | OTHER
  fileName      String
  filePath      String  // uploads/leverandoer/[vendorNo]/[id].[ext]
  mimeType      String
  fileSize      Int
  uploadedAt    DateTime @default(now())

  @@index([declarationId])
}

model SupplierReminderLog {
  id            String              @id @default(cuid())
  declaration   SupplierDeclaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  declarationId String
  type          String  // INITIAL | REMINDER_10M | ESCALATION_11M
  sentTo        String  // email-adresse
  sentAt        DateTime @default(now())

  @@index([declarationId])
}
